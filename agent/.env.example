# ═══════════════════════════════════════════════
# LEILÃO AGENT — CONFIGURATION
# ═══════════════════════════════════════════════

# Agent
AGENT_NAME=LeilãoAgent
AGENCY_NAME=Minha Imobiliária de Leilões
ORGANIZATION_ID=your-supabase-org-uuid-here

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# Supabase (same project as web/)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service_role_key...

# Redis
REDIS_URL=redis://localhost:6379/0

# WhatsApp (UAZ / Evolution API)
UAZ_BASE_URL=https://your-uaz-instance.com
UAZ_TOKEN=your-token
ADMIN_PHONES=5511999999999

# Scraper
SCRAPER_CAIXA_ENABLED=true
SCRAPER_INTERVAL_HOURS=12

# RAG (requires pgvector — disabled by default for Supabase)
RAG_ENABLED=false

# Flags
DRY_RUN=false
DEBUG=true
